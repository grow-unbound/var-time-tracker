# --- Supabase + Prisma ---
#
# Anon and service_role keys are for Supabase REST/Auth over HTTPS. Prisma Migrate and Prisma Client
# require a PostgreSQL connection string — you cannot replace DATABASE_URL/DIRECT_URL with those keys.
#
# If db.[PROJECT].supabase.co (Direct) fails from your network (IPv4/IPv6), use the Session pooler
# for DIRECT_URL instead: same pooler host as DATABASE_URL but port 5432 and no ?pgbouncer=true.
# Copy it from Supabase → Project Settings → Database → Connection string → Session pooler.

# Transaction pooler — runtime (Next.js / Vercel) + PrismaClient
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations (prisma migrate deploy). Use ONE of the following:
# A) Session pooler (often works when "Direct" host is blocked; IPv4-friendly)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
# B) Direct Postgres (Prisma default recommendation when it works)
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Vercel: set DATABASE_URL and DIRECT_URL on the project. Build runs prisma migrate deploy.
# First-time: npx prisma migrate deploy && npx prisma db seed
